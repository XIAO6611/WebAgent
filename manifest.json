{
  "manifest_version": 3,
  "name": "多模态 Web Agent 助手",
  "version": "1.0.1",
  "description": "基于 VLM 和原生插件架构的网页智能交互助手",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "downloads" 
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "唤起 Agent"
  },
  "options_page": "options.html", 
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}